# ============================================================
# Copie ce fichier en .env et remplis les valeurs locales
# CE FICHIER .env NE DOIT JAMAIS ÊTRE POUSSÉ SUR GITHUB
# ============================================================

# Base de données locale
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=TON_MOT_DE_PASSE_MYSQL_LOCAL
DB_NAME=positive_distribution

# JWT (change cette valeur en production)
JWT_SECRET=dev_secret_local_12345

# Serveur
PORT=3001
NODE_ENV=development
